clc
clear

[x1, t1, U1] = diffusion1D( 0.1, [0,1], 6, [1, 3], 12, @u2a_init, @u2a_bndry );
%2.8a fig 1

U11 = U1' %i dont know why it needs to be transposed to work

figure;
mesh(x1,t1,U11)
xlabel('x');
ylabel('y');
zlabel('u(t,x)')
title('n4du...')
colorbar;

[x2, t2, U2] = diffusion1D( 0.1, [0,1], 100, [1, 3], 4000, @u2a_init, @u2a_bndry );
%2.8a fig 2

U22 = U2'

figure;
mesh(x2,t2,U22)
xlabel('x');
ylabel('y');
zlabel('u(t,x)')
title('n4du...')
colorbar;
